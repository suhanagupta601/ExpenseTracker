import SwiftUI

@Observable
final class ThemeManager {
    var current: AppTheme = .sageGarden
    var customThemes: [AppTheme] = []      // user-made — persist these later

    var allThemes: [AppTheme] { AppTheme.builtIns + customThemes }

    func select(_ theme: AppTheme) { current = theme }

    func addCustom(_ theme: AppTheme) {
        var t = theme; t.isBuiltIn = false
        customThemes.append(t)
        current = t
    }
}
