import SwiftUI

struct AppTheme: Identifiable, Codable, Hashable {
    var id: UUID = UUID()
    var name: String
    var isBuiltIn: Bool = false

    // Stored as hex so themes are Codable and user-creatable
    var backgroundHex: String
    var surfaceHex: String
    var textPrimaryHex: String
    var textSecondaryHex: String
    var accentHex: String
    var underBudgetHex: String
    var overBudgetHex: String
    var categoryHexes: [String]

    // Convenience accessors — views use these, never raw hex
    var background: Color    { Color(hex: backgroundHex) ?? .gray }
    var surface: Color       { Color(hex: surfaceHex) ?? .gray }
    var textPrimary: Color   { Color(hex: textPrimaryHex) ?? .black }
    var textSecondary: Color { Color(hex: textSecondaryHex) ?? .gray }
    var accent: Color        { Color(hex: accentHex) ?? .gray }
    var underBudget: Color   { Color(hex: underBudgetHex) ?? .green }
    var overBudget: Color    { Color(hex: overBudgetHex) ?? .red }
    var categories: [Color]  { categoryHexes.compactMap { Color(hex: $0) } }
}

